---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "LagSync: The #1 extension to fix Bluetooth audio delay. Compatible with Chrome, Firefox, Safari, Edge, and Brave." } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icon_16_simple.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon_32_simple.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/icon_48_simple.png" />
    <link rel="apple-touch-icon" sizes="128x128" href="/icon_128_simple.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=IBM+Plex+Sans:wght@300;400;600&display=swap" rel="stylesheet">

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="bg-[#080808] text-slate-200 font-['IBM_Plex_Sans'] antialiased selection:bg-cyan-500/30">
    <slot />
  </body>
</html>