---
import PromoRotator from './PromoRotator.astro';
import { VERSION } from '../config';
---

<section class="relative pt-32 pb-12 overflow-hidden flex flex-col items-center">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-gradient-to-b from-cyan-900/20 to-transparent blur-3xl -z-10"></div>

  <div class="container mx-auto px-6 text-center relative z-10">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-cyan-400 text-xs font-['Space_Mono'] mb-8">
      <span class="w-2 h-2 rounded-full bg-cyan-500 animate-pulse"></span>
      Version {VERSION} — Compatible with top browsers
    </div>

    <h1 class="text-5xl md:text-8xl font-bold mb-6 tracking-tighter text-white">
      LAG<span class="text-cyan-500">SYNC</span>
    </h1>
    
    <p class="text-xl md:text-2xl text-slate-400 max-w-2xl mx-auto mb-10 font-light leading-relaxed">
      The professional standard for <span class="text-white">fixing Bluetooth audio delay</span> on any website. Sub-millisecond precision for the perfect watch party.
    </p>
    
    <div class="flex flex-col sm:flex-row justify-center gap-4 mb-12">
      <a id="install-cta" href="https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf" class="px-10 py-4 bg-cyan-500 text-black font-bold rounded-full hover:bg-cyan-400 transition-all hover:shadow-[0_0_30px_rgba(34,211,238,0.4)]">
        Install now
      </a>
      <a href="#download" class="px-8 py-4 border border-white/10 text-white rounded-full hover:bg-white/5 transition-all">
        See other browsers
      </a>
    </div>

    <PromoRotator />

    <script type="module">
      (function () {
        const install = document.getElementById('install-cta');
        if (!install) return;
        const chromeUrl = 'https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf';
        const firefoxUrl = 'https://addons.mozilla.org/en-US/firefox/addon/lagsync-bluetooth-audio-fix/';
        const edgeUrl = 'https://microsoftedge.microsoft.com/addons/detail/lagsync-bluetooth-audio/ocigopodjjobggdnklngfaceeedlkbol';
        const ua = navigator.userAgent || '';
        const isFirefox = /firefox/i.test(ua) && !/seamonkey/i.test(ua);
        const isSafari = /safari/i.test(ua) && !/chrome|chromium|crios|android/i.test(ua);
        const isEdge = /edg/i.test(ua);
        if (isSafari) {
          install.textContent = 'Coming soon';
          install.href = '/#download';
          install.removeAttribute('target');
          install.removeAttribute('rel');
        } else if (isFirefox) {
          install.textContent = 'Add to Firefox';
          install.href = firefoxUrl;
          install.target = '_blank';
          install.rel = 'noopener noreferrer';
        } else if (isEdge) {
          install.textContent = 'Add to Edge';
          install.href = edgeUrl;
          install.target = '_blank';
          install.rel = 'noopener noreferrer';
        } else {
          install.textContent = 'Install now';
          install.href = chromeUrl;
          install.target = '_blank';
          install.rel = 'noopener noreferrer';
        }
      })();
    </script>

  </div>
</section>
