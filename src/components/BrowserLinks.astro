---
const browsers = [
  { name: 'Chrome', icon: '/icons/chrome.svg', note: 'v1.01 — Live', link: 'https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf' },
  { name: 'Firefox', icon: '/icons/firefox.svg', note: 'Coming Soon', link: '#' },
  { name: 'Edge', icon: '/icons/edge.svg', note: 'v1.01 — Live', link: 'https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf' },
  { name: 'Safari', icon: '/icons/safari.svg', note: 'Coming Soon', link: '#' },
  { name: 'Brave', icon: '/icons/brave.svg', note: 'v1.01 — Live', link: 'https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf' },
];
---

<section id="download" class="py-20">
  <div class="container mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold text-white mb-12 font-['Space_Mono'] uppercase tracking-widest">Install LagSync</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      {browsers.map((browser) => (
        <a href={browser.link} target="_blank" rel="noopener noreferrer" class="group p-6 rounded-2xl bg-[#111] border border-white/5 hover:border-cyan-500/50 hover:bg-[#161616] transition-all duration-300">
          <img src={browser.icon} alt={browser.name} class="w-10 h-10 mx-auto mb-4 group-hover:scale-110 transition-transform" />
          <div class="font-bold text-white group-hover:text-cyan-400 transition-colors">{browser.name}</div>
          <div class="text-[10px] uppercase tracking-tighter text-slate-400 mt-1">{browser.note}</div>
        </a>
      ))}
    </div>
  </div>
</section>