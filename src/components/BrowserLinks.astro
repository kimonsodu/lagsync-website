---
const browsers = [
  { name: 'Chrome', icon: '🌐', note: 'Primary', link: '#' },
  { name: 'Firefox', icon: '🦊', note: 'Add-ons Store', link: '#' },
  { name: 'Edge', icon: '🌀', note: 'Chromium', link: '#' },
  { name: 'Safari', icon: '🧭', note: 'macOS / iOS', link: '#' },
  { name: 'Brave', icon: '🦁', note: 'Native Support', link: '#' },
];
---

<section id="download" class="py-20">
  <div class="container mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold text-white mb-12 font-['Space_Mono'] uppercase tracking-widest">Available Everywhere</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      {browsers.map((browser) => (
        <a href={browser.link} class="group p-6 rounded-2xl bg-[#111] border border-white/5 hover:border-cyan-500/50 hover:bg-[#161616] transition-all duration-300">
          <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">{browser.icon}</div>
          <div class="font-bold text-white group-hover:text-cyan-400 transition-colors">{browser.name}</div>
          <div class="text-[10px] uppercase tracking-tighter text-slate-500 mt-1">{browser.note}</div>
        </a>
      ))}
    </div>
  </div>
</section>