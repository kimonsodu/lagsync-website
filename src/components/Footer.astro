---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0a0a0a] border-t border-white/5 py-12">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="font-['Space_Mono'] font-bold text-xl text-white tracking-tighter">
        LAG<span class="text-cyan-500">SYNC</span>
      </div>
      
      <nav class="flex gap-8 text-[11px] font-['Space_Mono'] uppercase tracking-widest text-slate-500">
        <a href="/#features" class="hover:text-cyan-400 transition-colors">Features</a>
        <a href="/privacy" class="hover:text-cyan-400 transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-cyan-400 transition-colors">Terms & License</a>
        <a href="mailto:support@lagsync.com" class="hover:text-cyan-400 transition-colors">Support</a>
      </nav>
      
      <p class="text-slate-600 text-[10px] font-['Space_Mono'] uppercase">
        &copy; {currentYear} LagSync Project
      </p>
    </div>
  </div>
</footer>