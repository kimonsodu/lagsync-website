---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0a0a0a] border-t border-white/5 py-12">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="font-['Space_Mono'] font-bold text-xl text-white tracking-tighter">
        LAG<span class="text-cyan-500">SYNC</span>
      </div>
      
      <nav class="flex gap-8 text-[11px] font-['Space_Mono'] uppercase tracking-widest text-slate-500">
        <a href="/" class="hover:text-cyan-400 transition-colors">Home</a>
        <a href="/privacy" class="hover:text-cyan-400 transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-cyan-400 transition-colors">Terms & License</a>
        <a href="/help" class="hover:text-cyan-400 transition-colors">Help</a>
        <a href="/donate" class="text-cyan-400 hover:text-white transition-colors flex items-center gap-1">
            Buy me a coffee ☕
        </a>
      </nav>
      
      <p class="text-slate-600 text-[10px] font-['Space_Mono'] uppercase">
        &copy; {currentYear} LagSync Project
      </p>
    </div>
    <div class="flex flex-col gap-3">
        <span class="text-white font-bold">Solutions</span>
        <a href="/fix/youtube" class="hover:text-cyan-400 transition-colors">YouTube Sync</a>
        <a href="/fix/netflix" class="hover:text-cyan-400 transition-colors">Netflix Sync</a>
    </div>
  </div>
</footer>