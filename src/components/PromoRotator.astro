---
const slides = [
  { src: '/images/Promotile.png', alt: 'LagSync promo tile', caption: 'Install LagSync — Chrome Web Store', link: 'https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf' },
  { src: '/images/Screenshot1.png', alt: 'YouTube popup', caption: 'Perfect lip-sync — settings optimized for streaming sites' },
  { src: '/images/Screenshot2.png', alt: 'Presets closeup', caption: 'Smart headset presets — aptX · AAC · SBC · High' },
  { src: '/images/Screenshot3.png', alt: 'Privacy header', caption: 'Privacy-first — local processing, no tracking, no ads' }
];

const slidesJson = JSON.stringify(slides);
---

<div class="mt-6 flex justify-center px-2 sm:px-4">
  <div id="pr-root" data-slides={slidesJson} class="w-full max-w-3xl bg-[#0b0b0b] border border-white/5 rounded-2xl p-2 sm:p-4 flex items-center gap-2 sm:gap-4">
    <button id="pr-prev" class="text-white/80 text-xl sm:text-2xl px-2 sm:px-3 py-2 rounded hover:bg-white/5 flex-shrink-0">‹</button>
    <a id="pr-link" href={slides[0].link || slides[0].src} target="_blank" rel="noopener noreferrer" class="flex-1 min-w-0">
      <div class="rounded-lg overflow-hidden bg-[#050505] flex items-center justify-center pr-frame">
        <img id="pr-img" src={slides[0].src} alt={slides[0].alt} class="w-full h-full object-contain" loading="lazy" />
      </div>
      <div id="pr-caption" class="pr-caption">{slides[0].caption}</div>
    </a>
    <button id="pr-next" class="text-white/80 text-xl sm:text-2xl px-2 sm:px-3 py-2 rounded hover:bg-white/5 flex-shrink-0">›</button>
  </div>
</div>

<script>
  import { Carousel, readItems } from '../scripts/gallery';

  const root = document.getElementById('pr-root');
  const img = document.getElementById('pr-img');
  const cap = document.getElementById('pr-caption');
  const link = document.getElementById('pr-link');

  if (root && img && cap && link) {
    new Carousel(readItems(root, 'slides'), {
      img: img as HTMLImageElement,
      caption: cap,
      link: link as HTMLAnchorElement,
      prevBtn: document.getElementById('pr-prev'),
      nextBtn: document.getElementById('pr-next'),
      hoverTarget: root,
      intervalMs: 5000,
    });
  }
</script>

<style>
  /* Stable frame for promo rotator to avoid layout shift when slides change */
  .pr-frame {
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 160px;
    max-height: 420px;
    display: block;
    background: #050505;
    position: relative;
  }
  .pr-frame img#pr-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }
  .pr-caption {
    margin-top: 0.5rem;
    padding: 0.2rem 0.6rem;
    color: #94a3b8; /* slate-400 */
    font-size: 0.8125rem; /* text-xs */
    text-align: center;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }
</style>
