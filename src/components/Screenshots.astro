---
import { SCREENSHOTS } from '../config';

const marquee = SCREENSHOTS.find(i => i.type === 'marquee');
const gallery = SCREENSHOTS.filter(i => i.type !== 'marquee');
const galleryJson = JSON.stringify(gallery);
---

<section class="container mx-auto px-6 py-12">
  <div class="max-w-5xl mx-auto text-center mb-6">
    <h2 class="text-3xl font-bold text-white mb-2 font-['Space_Mono']">See LagSync in Action</h2>
    <p class="text-slate-400">Featured promo and interactive screenshots — click any image to open a full-size viewer.</p>
  </div>

  <!-- Featured marquee banner (clickable based on browser) -->
  {marquee ? (
    <div id="ls-marquee" class="mb-8 ls-breakout">
      <a id="ls-marquee-link" class="block" href="#" aria-label="Open store listing">
        <div class="ls-marquee-frame rounded-2xl overflow-hidden shadow-lg">
          <img src={marquee.src} alt={marquee.alt} class="w-full h-full object-cover ls-marquee-img" />
        </div>
      </a>
    </div>
  ) : null}

  <div id="ls-gallery" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start" data-gallery={galleryJson}>
    <!-- Large promo tile / featured image -->
    {gallery && gallery.length > 0 ? (
      <div class="md:col-span-1">
        <div class="bg-[#0b0b0b] border border-white/5 rounded-2xl overflow-hidden cursor-pointer hover:scale-[1.02] transition-transform flex flex-col items-stretch" data-lightbox-index="0" role="button" aria-label="Open featured image">
          <div class="flex items-center justify-center bg-[#050505] p-4">
            <img src={gallery[0].src} alt={gallery[0].alt} class="max-h-[420px] w-auto max-w-full object-contain" />
          </div>
          <div class="p-4 text-sm text-slate-400 text-center">{gallery[0].caption}</div>
        </div>
      </div>
    ) : null}

    <!-- Grid of screenshots (responsive) -->
    <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {gallery.slice(1).map((img, i) => (
        <figure class="bg-[#0b0b0b] border border-white/5 rounded-2xl overflow-hidden cursor-pointer hover:scale-[1.01] transition-transform" data-lightbox-index={i + 1} role="button" aria-label={`Open ${img.caption}`}>
          <div class="flex items-center justify-center bg-[#050505] p-2">
            <img src={img.src} alt={img.alt} loading="lazy" class="max-h-[320px] w-auto max-w-full object-contain" />
          </div>
          <figcaption class="p-3 text-sm text-slate-400 text-center">{img.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>

  <!-- Lightbox / viewer -->
  <div id="ls-lightbox" class="fixed inset-0 z-50 hidden flex-col items-center justify-center bg-black/80 p-6">
    <button id="ls-close" class="absolute top-6 right-6 text-white text-3xl leading-none" aria-label="Close">×</button>
    <button id="ls-prev" class="absolute left-6 text-white text-4xl leading-none" aria-label="Previous">‹</button>
    <div class="max-w-[90vw] max-h-[80vh] flex items-center justify-center">
      <img id="ls-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg shadow-lg" />
    </div>
    <div id="ls-caption" class="text-slate-300 mt-4 text-center"></div>
    <button id="ls-next" class="absolute right-6 text-white text-4xl leading-none" aria-label="Next">›</button>
  </div>

  <script>
    import { Lightbox, readItems } from '../scripts/gallery';

    const root = document.getElementById('ls-gallery');
    const lb = document.getElementById('ls-lightbox');
    const img = document.getElementById('ls-img');
    const cap = document.getElementById('ls-caption');

    if (root && lb && img && cap) {
      new Lightbox(readItems(root, 'gallery'), {
        root: lb,
        img: img as HTMLImageElement,
        caption: cap,
        triggerScope: root,
        prevBtn: document.getElementById('ls-prev'),
        nextBtn: document.getElementById('ls-next'),
        closeBtn: document.getElementById('ls-close'),
      });
    }
  </script>

  <script>
    (function() {
      const marqueeLink = document.getElementById('ls-marquee-link');
      if (!marqueeLink) return;
      const chromeUrl = 'https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf';
      const firefoxUrl = 'https://addons.mozilla.org/en-US/firefox/addon/lagsync-bluetooth-audio-fix/';
      const edgeUrl = 'https://microsoftedge.microsoft.com/addons/detail/lagsync-bluetooth-audio/ocigopodjjobggdnklngfaceeedlkbol';
      const ua = navigator.userAgent || '';
      const isFirefox = /firefox/i.test(ua) && !/seamonkey/i.test(ua);
      const isSafari = /safari/i.test(ua) && !/chrome|chromium|crios|android/i.test(ua);
      const isEdge = /edg/i.test(ua);
      let href = chromeUrl;
      if (isSafari) href = '/#download';
      else if (isFirefox) href = firefoxUrl;
      else if (isEdge) href = edgeUrl;
      marqueeLink.href = href;
      if (href === '/#download') {
        marqueeLink.removeAttribute('target');
        marqueeLink.removeAttribute('rel');
      } else {
        marqueeLink.target = '_blank';
        marqueeLink.rel = 'noopener noreferrer';
      }
    })();
  </script>

  <!-- marquee link/compact behavior removed: static banner -->

  <style>
    /* Make marquee full-bleed and lock to 4.9333:1 aspect ratio (screen-wide) */
    /* Prevent horizontal scroll caused by full-bleed breakout.
       We add a tiny reduction from 100vw and hide any leftover overflow. */
    html, body { overflow-x: hidden; }

    .ls-breakout {
      position: relative;
      width: calc(100vw - 1px);
      max-width: 100vw;
      /* Use calc-based margins to escape container padding without overflowing */
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      box-sizing: border-box;
      overflow-x: hidden;
    }
    /* Frame enforcing exact aspect ratio; image fills the frame (full-width wide) */
    .ls-marquee-frame {
      width: 100%;
      aspect-ratio: 4.93333333333 / 1;
      overflow: hidden;
      display: block;
    }
    .ls-marquee-frame img.ls-marquee-img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center;
    }
  </style>
</section>
