---
const images = [
  { src: '/images/marquee.png', alt: 'LagSync marquee banner', caption: 'Marquee banner', type: 'marquee' },
  { src: '/images/Promotile.png', alt: 'LagSync promo tile', caption: 'Promotional tile — Install now', type: 'promo' },
  { src: '/images/Screenshot1.png', alt: 'YouTube popup', caption: 'Perfect lip-sync — settings optimized for streaming sites' },
  { src: '/images/Screenshot2.png', alt: 'Presets closeup', caption: 'Smart headset presets — aptX · AAC · SBC · High' },
  { src: '/images/Screenshot3.png', alt: 'Privacy header', caption: 'Privacy-first — local processing, no tracking, no ads' },
  { src: '/images/Screenshot4.png', alt: 'Compatibility', caption: 'Universal compatibility — sync audio on any website' }
];

const marquee = images.find(i => i.type === 'marquee');
const gallery = images.filter(i => i.type !== 'marquee');
const galleryJson = JSON.stringify(gallery);
---

<section class="container mx-auto px-6 py-12">
  <div class="max-w-5xl mx-auto text-center mb-6">
    <h2 class="text-3xl font-bold text-white mb-2 font-['Space_Mono']">See LagSync in Action</h2>
    <p class="text-slate-400">Featured promo and interactive screenshots — click any image to open a full-size viewer.</p>
  </div>

  <!-- Featured marquee banner (clickable based on browser) -->
  {marquee ? (
    <div id="ls-marquee" class="mb-8 ls-breakout">
      <a id="ls-marquee-link" class="block" href="#" aria-label="Open store listing">
        <div class="ls-marquee-frame rounded-2xl overflow-hidden shadow-lg">
          <img src={marquee.src} alt={marquee.alt} class="w-full h-full object-cover ls-marquee-img" />
        </div>
      </a>
    </div>
  ) : null}

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
    <!-- Large promo tile / featured image -->
    {gallery && gallery.length > 0 ? (
      <div class="md:col-span-1">
        <div class="bg-[#0b0b0b] border border-white/5 rounded-2xl overflow-hidden cursor-pointer hover:scale-[1.02] transition-transform flex flex-col items-stretch" onclick={`openLightbox(0)`} role="button" aria-label="Open featured image">
          <div class="flex items-center justify-center bg-[#050505] p-4">
            <img src={gallery[0].src} alt={gallery[0].alt} class="max-h-[420px] w-auto max-w-full object-contain" />
          </div>
          <div class="p-4 text-sm text-slate-400 text-center">{gallery[0].caption}</div>
        </div>
      </div>
    ) : null}

    <!-- Grid of screenshots (responsive) -->
    <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {gallery.slice(1).map((img, i) => (
        <figure class="bg-[#0b0b0b] border border-white/5 rounded-2xl overflow-hidden cursor-pointer hover:scale-[1.01] transition-transform" onclick={`openLightbox(${i + 1})`} role="button" aria-label={`Open ${img.caption}`}>
          <div class="flex items-center justify-center bg-[#050505] p-2">
            <img src={img.src} alt={img.alt} loading="lazy" class="max-h-[320px] w-auto max-w-full object-contain" />
          </div>
          <figcaption class="p-3 text-sm text-slate-400 text-center">{img.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>

  <!-- Lightbox / viewer -->
  <div id="ls-lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-6">
    <button id="ls-close" class="absolute top-6 right-6 text-white text-3xl leading-none" onclick="closeLightbox()" aria-label="Close">×</button>
    <button id="ls-prev" class="absolute left-6 text-white text-4xl leading-none" onclick="prevImage()" aria-label="Previous">‹</button>
    <div class="max-w-[90vw] max-h-[80vh] flex items-center justify-center">
      <img id="ls-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg shadow-lg" />
    </div>
    <div id="ls-caption" class="text-slate-300 mt-4 text-center"></div>
    <button id="ls-next" class="absolute right-6 text-white text-4xl leading-none" onclick="nextImage()" aria-label="Next">›</button>
  </div>

  <script type="application/json" id="ls-gallery-data" set:html={galleryJson}></script>
  <script>
    (function(){
      const dataEl = document.getElementById('ls-gallery-data');
      const gallery = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];
      window.__LS_GALLERY = gallery;
      window.__LS_INDEX = 0;

      window.openLightbox = function(i) {
        const lb = document.getElementById('ls-lightbox');
        const imgEl = document.getElementById('ls-img');
        const cap = document.getElementById('ls-caption');
        const item = gallery[i];
        if (!item) return;
        window.__LS_INDEX = i;
        imgEl.src = item.src;
        imgEl.alt = item.alt || '';
        cap.textContent = item.caption || '';
        lb.classList.remove('hidden');
        lb.classList.add('flex');
        document.body.style.overflow = 'hidden';
      };

      window.closeLightbox = function() {
        const lb = document.getElementById('ls-lightbox');
        lb.classList.add('hidden');
        lb.classList.remove('flex');
        document.body.style.overflow = '';
      };

      window.prevImage = function() {
        window.__LS_INDEX = (window.__LS_INDEX - 1 + gallery.length) % gallery.length;
        window.openLightbox(window.__LS_INDEX);
      };

      window.nextImage = function() {
        window.__LS_INDEX = (window.__LS_INDEX + 1) % gallery.length;
        window.openLightbox(window.__LS_INDEX);
      };

      // Close on backdrop click
      document.addEventListener('click', (e) => {
        const lb = document.getElementById('ls-lightbox');
        if (!lb) return;
        if (!lb.classList.contains('hidden') && e.target === lb) window.closeLightbox();
      });

      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        const lb = document.getElementById('ls-lightbox');
        if (!lb || lb.classList.contains('hidden')) return;
        if (e.key === 'Escape') window.closeLightbox();
        if (e.key === 'ArrowLeft') window.prevImage();
        if (e.key === 'ArrowRight') window.nextImage();
      });
    })();
  </script>

  <script>
    (function() {
      const marqueeLink = document.getElementById('ls-marquee-link');
      if (!marqueeLink) return;
      const chromeUrl = 'https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf';
      const firefoxUrl = 'https://addons.mozilla.org/en-US/firefox/addon/lagsync-bluetooth-audio-fix/';
      const ua = navigator.userAgent || '';
      const isFirefox = /firefox/i.test(ua) && !/seamonkey/i.test(ua);
      const isSafari = /safari/i.test(ua) && !/chrome|chromium|crios|android/i.test(ua);
      const isEdge = /edg/i.test(ua);
      let href = chromeUrl;
      if (isSafari) href = '/#download';
      else if (isFirefox) href = firefoxUrl;
      else if (isEdge) href = chromeUrl;
      marqueeLink.href = href;
      if (href === '/#download') {
        marqueeLink.removeAttribute('target');
        marqueeLink.removeAttribute('rel');
      } else {
        marqueeLink.target = '_blank';
        marqueeLink.rel = 'noopener noreferrer';
      }
    })();
  </script>

  <!-- marquee link/compact behavior removed: static banner -->

  <style>
    /* Make marquee full-bleed and lock to 4.9333:1 aspect ratio (screen-wide) */
    .ls-breakout {
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      width: 100vw;
    }
    /* Frame enforcing exact aspect ratio; image fills the frame (full-width wide) */
    .ls-marquee-frame {
      width: 100%;
      aspect-ratio: 4.93333333333 / 1;
      overflow: hidden;
      display: block;
    }
    .ls-marquee-frame img.ls-marquee-img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center;
    }
  </style>
</section>
