---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="LagSync Guides — Fix Audio Delay"
  description="Step-by-step guides for fixing audio sync on YouTube, Netflix, Twitch, and Prime Video using LagSync.">
  <main class="bg-[#080808] text-white flex-grow">
    <section class="pt-32 pb-12">
      <div class="container mx-auto px-6 text-center">
        <div class="inline-block px-4 py-1 rounded-full border border-white/10 bg-white/5 text-xs font-['Space_Mono'] uppercase tracking-widest mb-6">Guides</div>
        <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">Fix Audio Sync on Popular Sites</h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10">Step-by-step guides for YouTube, Netflix, Twitch, and Prime Video.</p>
      </div>
    </section>

    <section class="py-20">
      <div class="container mx-auto px-6 max-w-4xl">
        <div class="grid md:grid-cols-2 gap-6">
          <a href="/fix/youtube" class="block p-6 rounded-2xl bg-[#0b0b0b] border border-white/5 hover:border-cyan-500/50 transition-all">
            <h3 class="text-2xl font-bold">YouTube</h3>
            <p class="text-slate-400 mt-2">Adaptive DASH streaming; tips for quality lock, presets, and audio mode.</p>
          </a>

          <a href="/fix/netflix" class="block p-6 rounded-2xl bg-[#0b0b0b] border border-white/5 hover:border-cyan-500/50 transition-all">
            <h3 class="text-2xl font-bold">Netflix</h3>
            <p class="text-slate-400 mt-2">DRM-backed adaptive streams; guidance for buffering, presets, and resync tricks.</p>
          </a>

          <a href="/fix/twitch" class="block p-6 rounded-2xl bg-[#0b0b0b] border border-white/5 hover:border-cyan-500/50 transition-all">
            <h3 class="text-2xl font-bold">Twitch</h3>
            <p class="text-slate-400 mt-2">Live variable-bitrate streams and overlays — baseline presets and performance tips.</p>
          </a>

          <a href="/fix/prime-video" class="block p-6 rounded-2xl bg-[#0b0b0b] border border-white/5 hover:border-cyan-500/50 transition-all">
            <h3 class="text-2xl font-bold">Prime Video</h3>
            <p class="text-slate-400 mt-2">DRM players and adaptive bitrate: small-buffer presets and reloading tips.</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
