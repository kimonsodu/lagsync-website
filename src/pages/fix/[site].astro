---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { execFileSync } from 'child_process';

export function getStaticPaths() {
  let defaultLastUpdated = new Date().toISOString();
  try {
    const out = execFileSync('git', ['log', '-1', '--format=%cI', '--', 'src/pages/fix/[site].astro'], { encoding: 'utf8' }).trim();
    if (out) defaultLastUpdated = out;
  } catch (e) {
    // ignore and keep ISO fallback
  }
  const paths = [
    { 
      params: { site: 'youtube' }, 
      props: { 
        name: 'YouTube', 
        color: '#FF0000',
        tip: 'YouTube often uses high-bitrate AAC. If the lag feels inconsistent, try a fixed preset like 180ms.',
        lastUpdated: '2026-04-07'
      } 
    },
    { 
      params: { site: 'netflix' }, 
      props: { 
        name: 'Netflix', 
        color: '#E50914',
        tip: 'Netflix uses heavy buffering. If you change the delay, give it ~30 seconds to "catch up" to the new offset or reload for instant effect.',
        lastUpdated: '2026-04-07'
      } 
    },
      {
        params: { site: 'twitch' },
        props: {
          name: 'Twitch',
          color: '#6441A4',
          tip: 'Twitch uses live HLS streams. If audio drifts during live streams, pause briefly after adjusting the delay or use the built-in latency tester.',
          lastUpdated: '2026-04-07'
        }
      },
      {
        params: { site: 'prime-video' },
        props: {
          name: 'Prime Video',
          color: '#00A8E1',
          tip: 'Prime Video may buffer aggressively. After changing the offset, allow a few seconds for playback to resync or try reloading.',
          lastUpdated: '2026-04-10'
        }
      },
  ];
  // Ensure each page has a `lastUpdated` prop; allow manual overrides in the props above.
  return paths.map(p => ({
    ...p,
    props: {
      ...p.props,
      lastUpdated: p.props.lastUpdated || defaultLastUpdated
    }
  }));

}
  const { site } = Astro.params;
const { name, color, tip, lastUpdated } = Astro.props;

const practicalTips = {
  youtube: {
    intro: 'YouTube uses adaptive streaming (DASH) and may switch audio codecs or bitrates mid-playback. Those switches can cause brief jitter or perceived sync shifts.',
    points: [
      'Lock playback quality in the player (gear → Quality) to avoid mid-stream codec/bitrate swaps.',
      'Start with a fixed preset around 180 ms and adjust in 20–50 ms increments until lip-sync looks correct.',
      "For music, podcasts, or dialog-heavy content, enable the extension's Audio Mode so audio timing is prioritized.",
      "If sync jumps after ads or quality changes, disable the extension's auto-settings so it doesn't re-tune mid-playback.",
      'For consistent testing, use a short clip with steady audio (no scene cuts) and adjust there.'
    ]
  },
  twitch: {
    intro: 'Twitch is a live, variable-bitrate platform with frequent scene and overlay changes — this increases the chance of transient desyncs.',
    points: [
      'Use a baseline preset of 200–250 ms for live streams; lower values risk underflow when frames drop.',
      'Use the canvas / live-edge pipeline when available — it is more robust across overlays and dynamic frame updates (may increase CPU usage).',
      'Force a single player quality if you see stuttering after auto-transcodes.',
      'Reduce CPU load (hide chat, close background tabs) if stuttering correlates with high CPU usage.'
    ]
  },
  'prime-video': {
    intro: 'Prime Video streams are often DRM-wrapped and use adaptive bitrate. Buffering can be aggressive.',
    points: [
      "Use a small buffer or the 'instant' preset to keep audio tight (start near 180 ms and fine-tune).",
      "Enable Audio Mode for dialog-heavy shows and movies.",
      'After changing extension settings, reload the player to reinitialize the pipeline — DRM players sometimes re-open media sessions on quality switches.',
      'If you experience drift during long plays, seek a few seconds forward/back to force a resync.'
    ]
  },
  netflix: {
    intro: 'Netflix uses DRM-backed adaptive streaming that can switch audio tracks or bitrates during playback.',
    points: [
      "Pick a consistent streaming quality in your Netflix account Playback Settings (use 'High' or a fixed setting for testing).",
      'Start with a fixed preset of 180–220 ms and adjust in small steps until lip-sync is correct.',
      'If you notice gradual drift over long sessions, try seeking a few seconds or reloading the tab to reinitialize playback.',
      "Toggle browser hardware acceleration as a troubleshooting step — it can sometimes affect timing on certain GPUs."
    ]
  }
};

const detailed = practicalTips[site];

function truncate(str, max = 155) {
  if (!str) return str;
  return str.length > max ? str.slice(0, max - 1) + '…' : str;
}

const description = (() => {
  const base = tip || (detailed && detailed.intro) || `Fix Bluetooth audio delay on ${name} with LagSync.`;
  return truncate(`${name} guide — ${base}`);
})();

---

<Layout
  title={`How to Fix ${name} Audio Delay | LagSync Guide`}
  dateModified={lastUpdated}
  description={description}
>
  <main class="bg-[#080808] text-white flex-grow">
    <section class="pt-32 pb-16 relative overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[400px] blur-[120px] opacity-10" style={`background: ${color}`}></div>
      
      <div class="container mx-auto px-6 text-center relative z-10">
        <div class="inline-block px-4 py-1 rounded-full border border-white/10 bg-white/5 text-xs font-['Space_Mono'] uppercase tracking-widest mb-6">
          Optimized for {name}
        </div>
        <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
          Sync your Audio <br/> on <span style={`color: ${color}`}>{name}</span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          Bluetooth latency makes {name} impossible to watch. LagSync fixes the delay at the engine level for perfect lip-sync.
        </p>
        {detailed ? (
          <>
            <p class="text-lg text-slate-300 max-w-2xl mx-auto mt-4">
              {detailed.intro}
            </p>
            {lastUpdated ? (
              <p class="text-sm text-slate-400 mt-3">Last updated: {new Date(lastUpdated).toLocaleDateString()}</p>
            ) : null}
          </>
        ) : null}
      </div>
    </section>

    <section class="py-20 border-t border-white/5">
      <div class="container mx-auto px-6 max-w-4xl">
        <h2 class="text-3xl font-bold mb-12 font-['Space_Mono'] text-center">Quick Setup Guide</h2>
        
        <div class="grid md:grid-cols-3 gap-8">
          <div class="flex flex-col items-center text-center">
            <div class="w-12 h-12 rounded-full bg-white text-black flex items-center justify-center font-bold mb-6">1</div>
            <h3 class="font-bold mb-3">Install & Pin</h3>
            <p class="text-sm text-slate-400">Add LagSync to your browser and pin it to your toolbar for quick access while watching.</p>
          </div>

          <div class="flex flex-col items-center text-center">
            <div class="w-12 h-12 rounded-full bg-white text-black flex items-center justify-center font-bold mb-6">2</div>
            <h3 class="font-bold mb-3">Play {name}</h3>
            <p class="text-sm text-slate-400">Open any video on {name}. LagSync will automatically detect the video engine and prepare the hook.</p>
          </div>

          <div class="flex flex-col items-center text-center">
            <div class="w-12 h-12 rounded-full bg-white text-black flex items-center justify-center font-bold mb-6">3</div>
            <h3 class="font-bold mb-3">Slide to Sync</h3>
            <p class="text-sm text-slate-400">Open the popup and move the slider. Your audio will shift in real-time until it fits the video perfectly. You could also use our built in latency tester.</p>
          </div>
        </div>
      </div>
    </section>

    {site === 'netflix' ? (
      <section class="py-12 bg-white/5">
        <div class="container mx-auto px-6 max-w-3xl">
          <div class="p-8 border border-cyan-500/30 rounded-2xl bg-[#0a0a0a]">
            <h4 class="text-cyan-400 font-['Space_Mono'] uppercase text-xs tracking-widest mb-4">Pro Tip for {name} Users</h4>
            <p class="text-slate-200 leading-relaxed italic">
              "{tip}"
            </p>
          </div>
        </div>
      </section>
    ) : null}

    {detailed ? (
      <section class="py-12">
        <div class="container mx-auto px-6 max-w-4xl">
          <h2 class="text-3xl font-bold mb-6 font-['Space_Mono'] text-center">Practical Tips</h2>
          <p class="text-slate-400 mb-4 text-center">{detailed.intro}</p>
          <div class="max-w-3xl mx-auto text-left text-slate-400">
            <ul class="list-disc list-inside space-y-3">
              {detailed.points.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    ) : null}

    <section class="py-24 text-center">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-bold mb-6">LagSync v1.01 — Available Now</h2>
        <p class="text-slate-400 mb-6 max-w-xl mx-auto">
          LagSync v1.01 is available now on Chrome, Firefox, Brave, and Edge. Safari support is coming soon.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a id="guide-install-cta" href="https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf" target="_blank" rel="noopener noreferrer" class="px-12 py-5 bg-cyan-500 text-black font-bold rounded-full hover:bg-cyan-400 transition-all">Install now</a>
          <a href="/fix" class="px-8 py-4 border border-white/10 text-white rounded-full hover:bg-white/5 transition-all">Browse all guides</a>
        </div>
      </div>
    </section>
    <script type="module">
      (function () {
        const install = document.getElementById('guide-install-cta');
        if (!install) return;
        const chromeUrl = 'https://chromewebstore.google.com/detail/lagsync-bluetooth-audio-f/ijhhkocgkagcfkoinilkjdcadljdjmaf';
        const firefoxUrl = 'https://addons.mozilla.org/en-US/firefox/addon/lagsync-bluetooth-audio-fix/';
        const ua = navigator.userAgent || '';
        const isFirefox = /firefox/i.test(ua) && !/seamonkey/i.test(ua);
        const isSafari = /safari/i.test(ua) && !/chrome|chromium|crios|android/i.test(ua);
        if (isSafari) {
          install.textContent = 'Coming soon';
          install.href = '/#download';
          install.removeAttribute('target');
          install.removeAttribute('rel');
        } else if (isFirefox) {
          install.textContent = 'Add to Firefox';
          install.href = firefoxUrl;
          install.target = '_blank';
          install.rel = 'noopener noreferrer';
        } else {
          install.textContent = 'Install now';
          install.href = chromeUrl;
          install.target = '_blank';
          install.rel = 'noopener noreferrer';
        }
      })();
    </script>
  </main>
  <Footer />
</Layout>
