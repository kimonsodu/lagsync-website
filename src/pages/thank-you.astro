---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Thank You | LagSync"
  description="Thanks for supporting LagSync — your contribution keeps the extension free, private, and ad-free.">
  <main class="pt-32 pb-20 flex-grow">
    <div class="container mx-auto px-6 max-w-2xl text-center">
      <div class="inline-block p-4 rounded-2xl bg-cyan-500/10 mb-8 border border-cyan-500/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 font-['Space_Mono'] uppercase tracking-tight">
        Thank <span class="text-cyan-500">You</span>
      </h1>

      <p class="text-lg text-slate-400 mb-12 leading-relaxed">
        Your support means the world. It keeps LagSync free, private, and ad-free for everyone. We'll keep building — because of people like you.
      </p>

      <a href="/" class="inline-block px-10 py-4 bg-white text-black font-bold rounded-full hover:bg-cyan-400 transition-all hover:shadow-[0_0_30px_rgba(34,211,238,0.4)]">
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
